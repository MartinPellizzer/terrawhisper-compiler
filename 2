.header {
    max-width: 128.0rem;
    margin-left: auto;
    margin-right: auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 3.2rem;
    margin-bottom: 3.2rem;
}

.button {
    display: inline-block;
    border: 1px solid black;
    padding: 1.2rem 2.4rem;
    text-transform: uppercase;
    font-size: 1.4rem;
    color: black;
    text-decoration: none;
}

.button-white {
    display: inline-block;
    border: 1px solid white;
    padding: 1.2rem 2.4rem;
    text-transform: uppercase;
    font-size: 1.4rem;
    color: white;
    text-decoration: none;
}

.homepage-hero-content {
    display: grid;
    align-items: center;
    height: 100%;
}

.homepage-hero-card {
    max-width: 76.8rem;
    background: white;
    padding: 3.2rem;
}

.homepage-hero-card-title {
    font-size: 7.2rem;
    line-height: 1;
    font-weight: 400;
    color: white;
    margin-right: 4.8rem;
}

@media (max-width: 768px) {
    .homepage-hero-card-title {
        font-size: 4.8rem;
    }
}

.homepage-what {
    padding-top: 9.6rem;
    padding-bottom: 9.6rem;
    max-width: 99.6rem;
    margin-left: auto;
    margin-right: auto;
    text-align: center;
}

.homepage-what-title {
    font-size: 3.6rem;
    line-height: 4.0rem;
    font-weight: 700;
    padding-top: 0;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
    margin-bottom: 2.4rem;
}

@media (max-width: 768px) {
    .homepage-what-title {
        font-size: 2.4rem;
        line-height: 3.2rem;
    }
}

.homepage-what-cards {
    display: grid;
    gap: 4.8rem;
    grid-template-columns: repeat(auto-fit, minmax(24rem, 1fr));
}

.homepage-articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(32rem, 1fr));
    gap: 2.4rem;
}

.homepage-articles-title {
    font-size: 3.6rem;
    line-height: 4.0rem;
}

.homepage-article-card a {
    color: black;
    text-decoration: none;
}

.homepage-article-title {
    font-size: 2.4rem;
    line-height: 3.2rem;
}

