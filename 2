@font-face {
    font-family: lato-regular;
    src: url("./assets/fonts/Lato/Lato-Regular.ttf");
}

@font-face {
    font-family: lato-bold;
    src: url("./assets/fonts/Lato/Lato-Bold.ttf");
}

.font-lato-regular {
    font-family: lato-regular;
    font-weight: 400;
}

.font-lato-bold {
    font-family: lato-bold;
    font-weight: 700;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

html {
    font-size: 62.5%;
}

body {
    font-size: 1.8rem;
    font-family: lato-regular, Arial, Helvetica, sans-serif;
}

/* ************************************************************ */
/* CONTAINER */
/* ************************************************************ */
.container-md {
    max-width: 76.8rem;
    margin: 0 auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
}

.container-lg {
    max-width: 128.0rem;
    margin: 0 auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
}

.container-xl {
    max-width: 128.0rem;
    margin: 0 auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
}

.container-xl-ext {
    max-width: 128.0rem;
    margin: 0 auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
}

.container-md-left {
    max-width: 76.8rem;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
}

.container-xl-half {
    max-width: 64.0rem;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
    margin-right: 0;
    margin-left: auto;
}

.bg-emerald-700 {
    background-color: #047857;
}

.bg-emerald-800 {
    background-color: #065f56;
}

.bg-emerald-900 {
    background-color: #064e3b;
}

.bg-emerald-950 {
    background-color: #022c22;
}

/* *************************************************************** */
/* BASIC */
/* *************************************************************** */
.logo {
    color: #030712;
    text-decoration: none;
}

h1 {
    font-size: 4.8rem;
    line-height: 1;
    padding-bottom: 1.6rem;
}

@media (max-width: 576px) {
    h1 {
        font-size: 3.6rem;
        line-height: 4.0rem;
    }
}

h2 {
    font-size: 3.6rem;
    line-height: 4.0rem;
    padding-top: 4.8rem;
    padding-bottom: 1.6rem;
}

p {
    margin-bottom: 1.6rem;
    line-height: 1.5;
}

ul {
    margin-left: 3.2rem;
    margin-bottom: 3.2rem;
}

ol {
    margin-left: 3.2rem;
    margin-bottom: 3.2rem;
}

li {
    margin-bottom: 0.8rem;
    line-height: 1.5;
}

img {
    width: 100%;
    display: block;
}

.icon {
    width: 3.6rem;
}

table {
    width: 100%;
    margin-bottom: 4.8rem;
    border-collapse: collapse;
}

th,
td {
    border: 1px solid;
    padding: 0.8rem 1.6rem;
}

