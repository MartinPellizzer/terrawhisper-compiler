/* *************************************************************** */
/* COMPONENTS */
/* *************************************************************** */
.button-secondary {
    display: inline-block;
    box-shadow: 0px 0px 0px 1px #030712;
    color: #030712;
    padding: 0.8rem 1.6rem;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 1px;
}

/* *************************************************************** */
/* ;toc */
/* *************************************************************** */
.toc {
    background-color: #fafafa;
    padding: 3.2rem;
}

.toc-title {
    display: inline-block;
    color: #404040;
    font-size: 4.0rem;
    margin-bottom: 3.2rem;
}

.toc ul {
    margin-bottom: 0;
}

/* ************************************************************ */
/* ;media */
/* ************************************************************ */
@media (max-width: 992px) {
    .grid-4 {
        grid-template-columns: 1fr 1fr 1fr;
    }

    .grid-3 {
        grid-template-columns: 1fr 1fr;
    }
}

@media (max-width: 768px) {
    .grid-4 {
        grid-template-columns: 1fr 1fr;
    }

    .grid-3 {
        grid-template-columns: 1fr;
    }

    .grid-2 {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 576px) {
    .grid-4 {
        grid-template-columns: 1fr;
    }

    .grid-3 {
        grid-template-columns: 1fr;
    }

    .home-hero-title {
        font-size: 3.2rem;
    }

    .home-hero-section {
        padding-top: 3.2rem;
    }

    .container-xl-ext {
        padding-left: 0;
        padding-right: 0;
    }
}

.cookie-box {
    background-color: #030712;
}

.cookie-box.hide {
    opacity: 0;
    visibility: hidden;
    background-color: #fafafa;
}


